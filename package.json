{
  "name": "auth-system-hybrid",
  "version": "1.0.0",
  "description": "Sistema de Autenticación Híbrido con Node.js - Passport, JWT, OAuth GitHub",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "jest --coverage --detectOpenHandles"
  },
  "keywords": [
    "auth",
    "jwt",
    "passport",
    "oauth",
    "nodejs",
    "express",
    "mongodb"
  ],
  "author": "Santiago Perez",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "connect-mongo": "^5.1.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-local": "^1.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.3",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/src/**/*.test.js"
    ],
    "verbose": true
  }
}
